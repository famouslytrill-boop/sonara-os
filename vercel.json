{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "public/**",
        "routes/**",
        "lib/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
