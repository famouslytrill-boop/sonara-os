{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run vercel-build",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "*": false
    }
  },
  "functions": {
    "api/index.js": {
      "includeFiles": "{public/**,routes/**,lib/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
