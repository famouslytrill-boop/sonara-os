{
  "name": "sonara-industries-operating-systems",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @sonara-industries/web dev",
    "dev:web": "pnpm --filter @sonara-industries/web dev",
    "build": "pnpm --filter @sonara-industries/web build",
    "lint": "pnpm --filter @sonara-industries/web lint",
    "typecheck": "pnpm --filter @sonara-industries/web typecheck",
    "test": "pnpm --filter @sonara-industries/web test",
    "stripe:seed": "node scripts/seed-stripe-products.mjs",
    "scan:secrets": "pnpm --dir .. run scan:secrets",
    "verify:db": "pnpm --dir .. run verify:db",
    "verify:security": "pnpm --dir .. run verify:security",
    "verify:entity-security": "pnpm --dir .. run verify:entity-security",
    "verify:brand": "pnpm --dir .. run verify:brand",
    "heartbeat": "pnpm --dir .. run heartbeat",
    "verify:all": "pnpm --dir .. run verify:all",
    "verify:postdeploy": "pnpm --dir .. run verify:postdeploy",
    "test:smoke": "pnpm --dir .. run test:smoke"
  },
  "devDependencies": {}
}
