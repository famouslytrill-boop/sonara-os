{
  "name": "signal-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm --dir frontend run lint",
    "verify:launch": "node scripts/verify-local-launch.mjs",
    "verify:security": "node scripts/verify-security.mjs",
    "scan:secrets": "powershell -ExecutionPolicy Bypass -File scripts/scan-secrets-local.ps1",
    "check:software": "node scripts/check-software.mjs",
    "bootstrap:local": "node scripts/bootstrap-local.mjs",
    "audit:deps": "node scripts/dependency-audit.mjs",
    "test": "pnpm --dir frontend run test",
    "test:smoke": "tsx tests/monorepo-smoke.test.mjs && tsx tests/entity-security-smoke.test.mjs",
    "test:brand": "tsx tests/brand-registry.test.mjs && node tests/brand-assets.test.mjs && node tests/brand-routes.test.mjs",
    "test:security": "pnpm run scan:secrets && pnpm run verify:security",
    "test:docs": "node scripts/check-doc-links.mjs",
    "typecheck": "tsc --noEmit",
    "validate:infrastructure": "node scripts/validate-infrastructure.mjs",
    "db:types": "pnpm exec supabase gen types typescript --local > types/supabase.ts",
    "db:diff": "pnpm exec supabase db diff --schema public",
    "db:push": "pnpm exec supabase db push",
    "db:reset": "pnpm exec supabase db reset",
    "python:health": "cd python && python -m sonara_ops.main health",
    "verify:db": "node scripts/verify-db-infrastructure.mjs",
    "verify:env": "node scripts/verify-env.mjs",
    "verify:stripe": "node scripts/verify-stripe-env.mjs",
    "workers:smoke": "node scripts/worker-smoke-test.mjs",
    "stripe:seed": "node scripts/seed-stripe-products.mjs",
    "heartbeat": "node scripts/entity-heartbeat-check.mjs",
    "heartbeat:entities": "node scripts/entity-heartbeat-check.mjs",
    "verify:heartbeat": "node scripts/verify-heartbeat.mjs",
    "seed:entities": "node scripts/seed-entity-defaults.mjs",
    "verify:entity-security": "node scripts/verify-entity-security.mjs",
    "verify:brand": "node scripts/verify-brand.mjs",
    "agent:worktree:create": "bash scripts/create-agent-worktree.sh",
    "agent:worktree:remove": "bash scripts/remove-agent-worktree.sh",
    "verify:all": "node scripts/verify-all.mjs",
    "verify:postdeploy": "node scripts/verify-postdeploy.mjs",
    "format": "prettier . --check",
    "check:local": "pnpm run validate:infrastructure && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.45.4",
    "@tailwindcss/postcss": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "postcss": "8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prettier": "^3.8.3",
    "supabase": "^2.98.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "5.0.6",
      "qs": "6.15.2",
      "postcss": "8.5.15",
      "next>postcss": "8.5.15",
      "next@16.2.6>postcss": "8.5.15",
      "postcss@<8.5.15": "8.5.15"
    }
  }
}
