{
  "name": "signal-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "verify:launch": "node scripts/verify-local-launch.mjs",
    "verify:security": "node scripts/verify-security.mjs",
    "scan:secrets": "powershell -ExecutionPolicy Bypass -File scripts/scan-secrets-local.ps1",
    "check:software": "node scripts/check-software.mjs",
    "bootstrap:local": "node scripts/bootstrap-local.mjs",
    "audit:deps": "node scripts/dependency-audit.mjs",
    "test": "tsx tests/monorepo-smoke.test.mjs",
    "typecheck": "tsc --noEmit",
    "validate:infrastructure": "node scripts/validate-sonara-full-infrastructure.mjs",
    "db:types": "npx supabase gen types typescript --local > types/supabase.ts",
    "db:diff": "npx supabase db diff --schema public",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "python:health": "cd python && python -m sonara_ops.main health",
    "verify:db": "node scripts/verify-db-infrastructure.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.45.4",
    "@tailwindcss/postcss": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "react": "^19",
    "react-dom": "^19",
    "recharts": "^3.8.1",
    "stripe": "^17.5.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.12"
  }
}
