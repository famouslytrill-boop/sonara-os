# Public frontend variables.
NEXT_PUBLIC_APP_URL=https://sonaraindustries.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=sonara-releases
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Server-only application variables.
SONARA_AI_PROVIDER=local_rules
SONARA_PROVIDER_TIMEOUT_MS=6000
SONARA_CRON_SECRET=

# Supabase server-only variables.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe server-only variables.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CREATOR_MONTHLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_LABEL_MONTHLY_PRICE_ID=

# Storage variables.
PUBLIC_ASSETS_BUCKET=public-assets
PRIVATE_ASSETS_BUCKET=sonara-user-assets
ORGANIZATION_ASSETS_BUCKET=sonara-organization-assets

# Worker variables.
REDIS_URL=
WORKER_CONCURRENCY=1

# Monitoring variables.
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional OpenAI BYOK mode. Set SONARA_AI_PROVIDER=openai_byok to use it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_FAST_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=medium
OPENAI_MAX_OUTPUT_TOKENS=700
OPENAI_STORE_RESPONSES=false

# Optional local model providers.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
LM_STUDIO_BASE_URL=http://127.0.0.1:1234
LM_STUDIO_MODEL=local-model

# Optional metadata-only sound discovery. Do not use these to auto-publish packs.
FREESOUND_API_KEY=
OPENVERSE_CLIENT_ID=
OPENVERSE_CLIENT_SECRET=
DATA_GOV_API_KEY=
NWS_USER_AGENT=
PUBLIC_DEMO_MODE=false
