# SONARA Industries SaaS launch env template.
# Keep real values in local .env, Vercel, Supabase, Stripe, Resend, or a password manager. Never commit real secrets.

NODE_ENV=development
PORT=3000

# Public deployment URL
NEXT_PUBLIC_SITE_URL=
PUBLIC_SITE_URL=
APP_URL=

# Supabase auth/database
# NEXT_PUBLIC_SUPABASE_URL must be the exact Project Settings -> API Project URL.
# Do not infer it from a project name and do not place service-role values in public variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BUSINESS_BUILDER_MONTHLY=
STRIPE_PRICE_ID_BUSINESS_BUILDER_ONETIME=
STRIPE_PRICE_ID_CREATOR_STUDIO_MONTHLY=
STRIPE_PRICE_ID_GROWTH_STUDIO_MONTHLY=

# Backward-compatible Stripe aliases used by older deploys
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_CORE_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_BUILDER_ONE_TIME=

# Resend email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SUPPORT_TO_EMAIL=
CONTACT_TO_EMAIL=

# Founder/admin access. Comma-separated emails.
FOUNDER_EMAILS=
ADMIN_EMAILS=
ADMIN_EMAIL=
SONARA_ADMIN_EMAILS=

# Deferred until Google OAuth provider is configured
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Optional AI gateway (OmniRoute). Operator/development use only.
# The public site never depends on these. Never route customer data through
# a local AI gateway and never expose these values to the browser.
# See docs/infrastructure/OPTIONAL_AI_GATEWAY.md
OMNIROUTE_ENABLED=false
OMNIROUTE_BASE_URL=http://localhost:20128/v1
OMNIROUTE_API_KEY=
OMNIROUTE_MODEL=auto
# Legacy aliases still honored by the readiness detector
SONARA_AI_GATEWAY_URL=
SONARA_AI_GATEWAY_KEY=

# Governed AI service adapters. Every adapter is disabled by default.
# Base URLs and credentials are read server-side only. Readiness probes never
# execute prompts, flows, tools, jobs, or customer actions.
SONARA_AI_INTEGRATION_PROBE_TIMEOUT_MS=1200

OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

N8N_ENABLED=false
N8N_BASE_URL=http://127.0.0.1:5678
N8N_API_KEY=

OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434

LANGFLOW_ENABLED=false
LANGFLOW_BASE_URL=http://127.0.0.1:7860
LANGFLOW_API_KEY=

DIFY_ENABLED=false
DIFY_BASE_URL=http://127.0.0.1:5001/v1
DIFY_API_KEY=

OPEN_WEBUI_ENABLED=false
OPEN_WEBUI_BASE_URL=http://127.0.0.1:3001
OPEN_WEBUI_API_KEY=

RAGFLOW_ENABLED=false
RAGFLOW_BASE_URL=http://127.0.0.1:9380
RAGFLOW_API_KEY=

CREWAI_ENABLED=false
CREWAI_WORKER_URL=http://127.0.0.1:8001
CREWAI_WORKER_TOKEN=

# Optional local-compose bootstrap secrets. Set strong, unique local values
# before starting the corresponding profile; never deploy these placeholders.
N8N_ENCRYPTION_KEY=
LANGFLOW_SUPERUSER=sonara-local-admin
LANGFLOW_SUPERUSER_PASSWORD=
LANGFLOW_SECRET_KEY=
OPEN_WEBUI_SECRET_KEY=
OPEN_WEBUI_ENABLE_SIGNUP=False

# Optional legacy/non-SaaS values preserved for compatibility with scripts/docs
DATABASE_URL=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=sonara-releases
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
ENVIRONMENT=development
SONARA_AI_PROVIDER=local_rules
SONARA_CRON_SECRET=
SONARA_PROVIDER_TIMEOUT_MS=6000
