ENVIRONMENT=development
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0
LITELLM_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:8000
ALLOWED_MODEL_LICENSES=MIT,Apache-2.0,BSD,ISC,MPL-2.0,Commercial-Approved

# Default launch mode. No paid API key required.
SONARA_AI_PROVIDER=local_rules
SONARA_CRON_SECRET=
SONARA_ADMIN_EMAILS=
SONARA_PROVIDER_TIMEOUT_MS=6000

# Optional OpenAI BYOK mode. Set SONARA_AI_PROVIDER=openai_byok to use it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_FAST_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=medium
OPENAI_MAX_OUTPUT_TOKENS=700
OPENAI_STORE_RESPONSES=false

# Optional local model providers.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
LM_STUDIO_BASE_URL=http://127.0.0.1:1234
LM_STUDIO_MODEL=local-model

# Optional Supabase launch services.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=sonara-releases

# Public deployment URL.
APP_URL=https://sonaraindustries.com
PUBLIC_SITE_URL=https://sonaraindustries.com
NEXT_PUBLIC_SITE_URL=https://sonaraindustries.com
NEXT_PUBLIC_APP_URL=https://sonaraindustries.com

# Optional Google sign-in. Deferred for launch until provider setup is complete.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Optional Stripe checkout. Required only when paid tiers go live.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_CORE_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_BUILDER_ONE_TIME=
STRIPE_PRICE_ID_BUSINESS_BUILDER_MONTHLY=
STRIPE_PRICE_ID_BUSINESS_BUILDER_ONETIME=
STRIPE_PRICE_ID_CREATOR_STUDIO_MONTHLY=
STRIPE_PRICE_ID_GROWTH_STUDIO_MONTHLY=
STRIPE_PRICE_BUSINESS_BUILDER_STARTER_MONTHLY=
STRIPE_PRICE_BUSINESS_BUILDER_CORE_MONTHLY=
STRIPE_PRICE_BUSINESS_BUILDER_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_BUILDER_ONETIME=
STRIPE_PRICE_CREATOR_STUDIO_STARTER_MONTHLY=
STRIPE_PRICE_CREATOR_STUDIO_CORE_MONTHLY=
STRIPE_PRICE_CREATOR_STUDIO_PRO_MONTHLY=
STRIPE_PRICE_GROWTH_STUDIO_STARTER_MONTHLY=
STRIPE_PRICE_GROWTH_STUDIO_CORE_MONTHLY=
STRIPE_PRICE_GROWTH_STUDIO_PRO_MONTHLY=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_CORE=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
STRIPE_PRICE_SETUP_99=
STRIPE_PRICE_SETUP_299=
STRIPE_PRICE_SETUP_499=
STRIPE_BUSINESS_BUILDER_PRICE_ID=
STRIPE_CREATOR_STUDIO_PRICE_ID=
STRIPE_GROWTH_STUDIO_PRICE_ID=

# Optional object storage. Use S3-compatible providers only when uploads are enabled.
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional advanced AI BYOK providers. The app must run without these.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
FREESOUND_API_KEY=
OPENVERSE_CLIENT_ID=
OPENVERSE_CLIENT_SECRET=

# Optional observability and open-source deployment helpers.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=sonara-industries
MINIO_ENDPOINT=
COOLIFY_PROJECT_ID=
DOKKU_APP_NAME=

# Optional support/contact providers. Do not commit real credentials.
SUPPORT_EMAIL=support@sonaraindustries.com
CONTACT_EMAIL=contact@sonaraindustries.com
SUPPORT_TO_EMAIL=
CONTACT_TO_EMAIL=
HELP_EMAIL=help@sonaraindustries.com
BILLING_EMAIL=billing@sonaraindustries.com
SECURITY_EMAIL=security@sonaraindustries.com
PRIVACY_EMAIL=privacy@sonaraindustries.com
LEGAL_EMAIL=legal@sonaraindustries.com
NEXT_PUBLIC_SUPPORT_CONTACT_LABEL=SONARA Support
RESEND_API_KEY=
RESEND_FROM_EMAIL=SONARA Industries <no-reply@sonaraindustries.com>
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Admin/founder access. Admin login uses Supabase email/password and server-side role checks.
ADMIN_EMAILS=
ADMIN_EMAIL=
FOUNDER_EMAILS=
